# Copy to .env on VM: cp gcp/vm/env.example gcp/vm/.env
# Generate secrets: bash gcp/vm/generate-env.sh

# Database (auto-created by Postgres container on first start)
POSTGRES_USER=skillplay
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=skillplay

# API
API_PORT=3000
CORS_ORIGIN=*

# Auth — run generate-env.sh to fill these
JWT_SECRET=CHANGE_ME_LONG_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_LONG_RANDOM

MOCK_PAYMENTS=true
FREE_PLAYS_PER_TOPIC=10
